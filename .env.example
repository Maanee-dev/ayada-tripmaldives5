# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# SUPABASE_URL: The URL of your Supabase project.
VITE_SUPABASE_URL="https://zocncwchaakjtsvlscmd.supabase.co"
# SUPABASE_ANON_KEY: The anonymous key for your Supabase project.
VITE_SUPABASE_ANON_KEY="sb_publishable_Ot34P55l4JGe2RjZywLovA_UokWsJ0I"
# SUPABASE_SERVICE_ROLE_KEY: Required for server-side Supabase operations (bypass RLS).
SUPABASE_SERVICE_ROLE_KEY="YOUR_SERVICE_ROLE_KEY"

# SMTP Configuration (Hostinger)
SMTP_HOST="smtp.hostinger.com"
SMTP_PORT=465
SMTP_USER="reservations@tripmaldives.co"
SMTP_PASS="YOUR_SMTP_PASSWORD"
SMTP_FROM='"TripMaldives" <reservations@tripmaldives.co>'
